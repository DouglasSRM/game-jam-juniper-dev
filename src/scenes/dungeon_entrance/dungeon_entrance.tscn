speaker_name = "Alex"
speaker_img = ExtResource("11_2gsd2")
speaker_img_HFrames = 2
text = "[shake rate=22.0 level=10 connected=0]NO! Wait grandpa[/shake]!!"
text_sound = ExtResource("13_cxqnp")
speaker_on_right = false
metadata/_custom_type_script = "uid://bu36cy11lb2of"

