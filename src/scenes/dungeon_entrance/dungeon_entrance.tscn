[sub_resource type="Resource" id="Resource_46yio"]
script = ExtResource("6_wd0pd")
target_path = NodePath("../..")
function_name = "start_grandpa_animation"
hide_dialogue_box = true
metadata/_custom_type_script = "uid://bwmccfplhqpda"

[sub_resource type="Resource" id="Resource_wd0pd"]
script = ExtResource("5_46yio")
speaker_name = "???"
text = "Oh! Hello son!"
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_eafeo"]
script = ExtResource("5_46yio")
speaker_name = "Alex"
text = "[shake rate=20.0 level=5 connected=0]aahh! Who's talking to me??![/shake]"
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_2gsd2"]
script = ExtResource("5_46yio")
speaker_name = "???"
text = "Up here son, looks like you will face a challenge, right?"
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_cxqnp"]
script = ExtResource("5_46yio")
speaker_name = "Alex"
text = "First of all, [shake rate=20.0 level=5 connected=0]WHO ARE YOU?[/shake] and what it's this challenge that you're talking about?"
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_wn36d"]
script = ExtResource("5_46yio")
speaker_name = "Alex Grandpa"
text = "How dare you not recognize your [shake rate=20.0 level=5 connected=0]oh-so-beloved grandfather[/shake]—kids these days..."
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_hxact"]
script = ExtResource("5_46yio")
speaker_name = "Alex Grandpa"
text = "Unfortunately, I couldn't go to the land of dead, and I'm trapped in this bottle for... well... multiple reasons. So, sometimes, I help the person holding this bottle awaken my [shake rate=20.0 level=5 connected=0]ultra special grandpa secret[/shake]."
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_2amhu"]
script = ExtResource("5_46yio")
speaker_name = "Alex"
text = "[shake rate=20.0 level=5 connected=0]Grandpa Secret?[/shake]"
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_qdwh1"]
script = ExtResource("5_46yio")
speaker_name = "Alex Grandpa"
text = "Oh yes, the abilitty of summon one of my golden age weapons to defeat your enemys, but be carefully you may invoke just one weapon at time. You will need this to the monster ahead."
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_hxwkn"]
script = ExtResource("5_46yio")
speaker_name = "Alex"
text = " [shake rate=20.0 level=10 connected=0]Mo-monster?[/shake] You are tolding me that have monsters here?"
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_ggxwx"]
script = ExtResource("5_46yio")
speaker_name = "Alex Grandpa"
text = "Good luck son..."
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_tmuql"]
script = ExtResource("5_46yio")
speaker_name = "Alex"
text = "[shake rate=22.0 level=10 connected=0]NO! Wait grandpa[/shake]."
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="RectangleShape2D" id="RectangleShape2D_46yio"]
size = Vector2(576, 20)

[sub_resource type="Resource" id="Resource_pk6ct"]
script = ExtResource("5_46yio")
speaker_name = "Uncle Reggie"
text = "I think now it's time. You are growing up buddy. This has been families hairloom for a long time... [shake rate=20.0 level=5 connected=0]The Grandpa's Secret[/shake]"
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_me2i1"]
script = ExtResource("5_46yio")
speaker_name = "ITEM"
text = "[rainbow freq=0.2 sat=10.0 val=20.0]ALEX RECEIVED A BOX[/rainbow]"
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_fg6a0"]
script = ExtResource("5_46yio")
speaker_name = "Alex"
text = "Excuse-me... like... a bottle?"
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_odb1k"]
script = ExtResource("5_46yio")
speaker_name = "Uncle Reggie"
text = "This has more meaning then it appears..."
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_s3hxo"]
script = ExtResource("5_46yio")
speaker_name = "Uncle Reggie"
text = "So Alex, a little secret for you, if you face danger:[rainbow freq=0.2 sat=10.0 val=20.0] spin the bottle[/rainbow]."
metadata/_custom_type_script = "uid://bu36cy11lb2of"

