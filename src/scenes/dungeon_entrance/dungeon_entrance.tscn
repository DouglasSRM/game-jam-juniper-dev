[sub_resource type="Resource" id="Resource_pk6ct"]
script = ExtResource("5_46yio")
speaker_name = "Uncle Reggie"
speaker_img = ExtResource("8_odb1k")
speaker_img_HFrames = 2
text = "I think now it's time. You are growing up buddy. This has been the familie's hairloom for a long time... [shake rate=20.0 level=5 connected=0]The Grandpa's Secret[/shake]"
