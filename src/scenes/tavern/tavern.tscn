[sub_resource type="Resource" id="Resource_gygia"]
script = ExtResource("6_a01i5")
speaker_name = "Uncle Reggie"
speaker_img = ExtResource("11_5tpw2")
speaker_img_HFrames = 2
speaker_img_step_frame = 2
text = "Ok, now that you've finished the cleaning on the  tavern room, we can talk about what happened earlier."
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_a01i5"]
script = ExtResource("6_a01i5")
speaker_name = "Alex"
speaker_img = ExtResource("8_5tpw2")
speaker_img_HFrames = 2
text = "This is not fair! if you [shake rate=20.0 level=5 connected=0]didn't stop me[/shake], I would've beaten his ass up!"
speaker_on_right = false
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_5tpw2"]
script = ExtResource("6_a01i5")
speaker_name = "Uncle Reggie"
speaker_img = ExtResource("9_5tpw2")
text = "[shake rate=20.0 level=5 connected=0]Not in my tavern![/shake] And if you raise your hand to [shake rate=20.0 level=5 connected=0]ANY[/shake]  customer again, I [shake rate=20.0 level=5 connected=0]WILL[/shake] beat your ass up!"
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_eet7p"]
script = ExtResource("8_a01i5")
target_path = NodePath("../..")
function_name = "tio_vai_embora"
hide_dialogue_box = true
wait_for_signal_to_continue = "plimbous"
metadata/_custom_type_script = "uid://bwmccfplhqpda"

[sub_resource type="Resource" id="Resource_cr8rw"]
script = ExtResource("6_a01i5")
speaker_name = "Uncle"
speaker_img = ExtResource("11_5tpw2")
speaker_img_HFrames = 2
text = "Common', you have more work to do."
metadata/_custom_type_script = "uid://bu36cy11lb2of"

[sub_resource type="Resource" id="Resource_i0pll"]
script = ExtResource("6_a01i5")
speaker_name = "Alex"
speaker_img = ExtResource("12_i0pll")
speaker_img_HFrames = 2
text = "Oh... I will not clean the toilets again! [shake rate=20.0 level=5 connected=0]Georgie was here today...[/shake"
